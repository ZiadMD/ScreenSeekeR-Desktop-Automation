# LLM Providers Configuration
# Primary provider: gemini | openai | groq | ollama | local
LLM_PROVIDER=gemini

# Primary APIs (Requires at least GEMINI_API_KEY if provider is gemini)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_URL=http://localhost:11434

# Models configuration
PLANNER_MODEL=gemini-3.1-flash-lite
GROUNDER_MODEL=gemini-3.1-flash-lite

# Split provider overrides (optional, enables hybrid mode)
# Example: Gemini planner + local GUI-Actor grounder
# PLANNER_PROVIDER=gemini
# GROUNDER_PROVIDER=local

# OpenAI alternative models (e.g., gpt-4o, gpt-4o-mini)
# Groq alternative models (e.g., llama-3.2-11b-vision-preview, llama-3.2-90b-vision-preview)
# Ollama alternative models (e.g., llama3.2-vision)

# Desktop & Display Settings
# Display scale factor (e.g., 1.10 for 110% scaling, 1.0 for 100% scaling)
DPI_SCALING=1.10

# Grounding settings
CONFIRMATION_STEP=true
MAX_SEARCH_DEPTH=3
MIN_PATCH_SIZE=256
IoU_THRESHOLD=0.3
CONFIDENCE_THRESHOLD=0.4

# API Settings
JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com/posts

# Logging
LOG_LEVEL=INFO

# Local Model Settings (only needed when a provider is set to "local")
# Path to model weights — relative to models/ dir, or absolute path
# LOCAL_MODEL_PATH=GUI-Actor-3B-Qwen2.5-VL
# LOCAL_MODEL_TYPE=gui-actor
# LOCAL_DEVICE=cuda:0
# LOCAL_TORCH_DTYPE=float16
# LOCAL_ATTN_IMPL=sdpa
