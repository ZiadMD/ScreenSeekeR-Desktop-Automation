# LLM Providers Configuration
# Primary provider: gemini | openai | groq | ollama
LLM_PROVIDER=gemini

# Primary APIs (Requires at least GEMINI_API_KEY if provider is gemini)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_API_URL=http://localhost:11434

# Models configuration
PLANNER_MODEL=gemini-2.0-flash
GROUNDER_MODEL=gemini-2.0-flash

# OpenAI alternative models (e.g., gpt-4o, gpt-4o-mini)
# Groq alternative models (e.g., llama-3.2-11b-vision-preview, llama-3.2-90b-vision-preview)
# Ollama alternative models (e.g., llama3.2-vision)

# Desktop & Display Settings
# Display scale factor (e.g., 1.10 for 110% scaling, 1.0 for 100% scaling)
DPI_SCALING=1.10

# Grounding settings
CONFIRMATION_STEP=true
MAX_SEARCH_DEPTH=3
MIN_PATCH_SIZE=256
IoU_THRESHOLD=0.3
CONFIDENCE_THRESHOLD=0.4

# API Settings
JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com/posts

# Logging
LOG_LEVEL=INFO
